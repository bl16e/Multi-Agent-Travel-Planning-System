abel>\n                <input type=\"number\" id=\"children\" min=\"0\" max=\"20\" value=\"0\">\n            </div>\n            <div class=\"form-group\">\n                <label for=\"budget_level\">预算等级</label>\n                <select id=\"budget_level\">\n                    <option value=\"budget\">经济型</option>\n                    <option value=\"mid_range\" selected>中等</option>\n                    <option value=\"luxury\">豪华</option>\n                </select>\n            </div>\n            <div class=\"form-group\">\n                <label for=\"total_budget\">总预算</label>\n                <input type=\"number\" id=\"total_budget\" min=\"0\" step=\"100\" placeholder=\"例：5000\">\n            </div>\n            <div class=\"form-group\">\n                <label for=\"currency\">货币</label>\n                <select id=\"currency\">\n                    <option value=\"USD\">USD</option>\n                    <option value=\"CNY\" selected>CNY</option>\n                    <option value=\"JPY\">JPY</option>\n                    <option value=\"EUR\">EUR</option>\n                    <option value=\"GBP\">GBP</option>\n                </select>\n            </div>\n            <div class=\"form-group\">\n                <label for=\"pace\">旅行节奏</label>\n                <select id=\"pace\">\n                    <option value=\"relaxed\">休闲</option>\n                    <option value=\"balanced\" selected>均衡</option>\n                    <option value=\"structured\">紧凑</option>\n                </select>\n            </div>\n            <div class=\"form-group full-width\">\n                <label for=\"interests\">兴趣标签（逗号分隔）</label>\n                <input type=\"text\" id=\"interests\" placeholder=\"例：美食, 文化, 自然风光\" value=\"美食, 文化, 城市漫步\">\n            </div>\n            <div class=\"form-group full-width\">\n                <label for=\"constraints\">特殊要求（逗号分隔）</label>\n                <input type=\"text\" id=\"constraints\" placeholder=\"例：无障碍设施, 素食餐厅\">\n  